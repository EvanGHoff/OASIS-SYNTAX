{
  "name": "oasis-syntax",
  "displayName": "Syntax Highlighting for OASIS",
  "description": "Syntax highlighting for OASIS (.oasis/.ini) files converted from Notepad++ UDL",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EvanGHoff/OASIS-SYNTAX"
  },
  "license": "MIT",
  "publisher": "Moog-EvanGHoff",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "oasis",
        "aliases": ["OASIS", "oasis"],
        "extensions": [".oasis", ".ini"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "oasis",
        "scopeName": "source.oasis",
        "path": "./syntaxes/oasis.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "OASIS Colors",
        "uiTheme": "vs-dark",
        "path": "./themes/oasis-colors.json"
      }
    ]
  },
  "keywords": ["oasis", "syntax", "highlighting", "ini", "moog", "genesys"]
}