{
  "name": "OASIS",
  "scopeName": "source.oasis",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords1" },
    { "include": "#keywords2" },
    { "include": "#keywords3" },
    { "include": "#keywords4" },
    { "include": "#keywords5" },
    { "include": "#keywords6" },
    { "include": "#keywords7" },
    { "include": "#keywords8" },
    { "include": "#directives" },
    { "include": "#values" },
    {
      "name": "keyword.operator.oasis",
      "match": "(=|:)"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.oasis",
          "match": "(#{|#}|#.*$)"
        }
      ]
    },
    "keywords1": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords1.oasis",
          "match": "\\b(?:CAS_ELEMENT|A429_PORT|ELEMENT|A429TX_PORT)(?=\\b\\s*=)"
        }
      ]
    },
    "keywords2": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords2.oasis",
          "match": "\\b(?:CAS_VALID1|VALID1|LIM1|CAS_VALID7|VALID7|LIM7)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "keywords3": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords3.oasis",
          "match": "\\b(?:CAS_VALID2|VALID2|LIM2|CAS_VALID8|VALID8|LIM8)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "keywords4": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords4.oasis",
          "match": "\\b(?:CAS_VALID3|VALID3|LIM3)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "keywords5": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords5.oasis",
          "match": "\\b(?:CAS_VALID4|VALID4|LIM4)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "keywords6": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords6.oasis",
          "match": "\\b(?:CAS_VALID5|VALID5|LIM5)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "keywords7": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords7.oasis",
          "match": "\\b(?:CAS_VALID_LOGIC|VALID_LOGIC|A429_LABEL|LABEL|LBL_\\S+)(?=\\b\\s*=)"
        }
      ]
    },
    "keywords8": {
      "patterns": [
        {
          "name": "keyword.declaration.keywords8.oasis",
          "match": "\\b(?:CAS_VALID6|VALID6|LIM6)\\S*(?=\\b\\s*=)"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.declaration.directives.oasis",
          "match": "(?:\\b(\\w+)\\b\\s*)(?=\\b\\s*=)"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.other.assignment.rhs.oasis",
          "match": "=\\s*(.*)$"
        }
      ]
    }
  }
}